---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Coming Soon | SynVoke">
    <div
        class="min-h-screen bg-[#050505] flex flex-col items-center justify-center relative overflow-hidden"
    >
        {/* Optional background glow */}
        <div class="absolute inset-0 max-w-7xl mx-auto">
            <div
                class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-indigo-500/10 blur-[100px] rounded-full pointer-events-none"
            >
            </div>
        </div>

        <div class="relative z-10 text-center px-6">
            <h1
                class="text-6xl md:text-8xl font-display font-bold text-white mb-6 tracking-tight"
            >
                Coming <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400"
                    >Soon</span
                >
            </h1>
            <p
                class="text-xl md:text-2xl text-gray-400 mb-12 max-w-2xl mx-auto font-light leading-relaxed"
            >
                This feature or page is currently under development. We are
                working hard to bring it to you soon.
            </p>

            <button
                onclick="history.back()"
                class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 hover:border-indigo-500/50 text-white font-medium transition-all duration-300 group"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="group-hover:-translate-x-1 transition-transform"
                >
                    <path d="m15 18-6-6 6-6"></path>
                </svg>
                Go Back To Previous Page
            </button>
        </div>
    </div>
</Layout>
