---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
import { ArrowLeft, ExternalLink, CheckCircle2 } from "lucide-react";

export function getStaticPaths() {
    return projects.map((project) => ({
        params: { id: project.id },
        props: { project },
    }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} - Premium Experience`}>
    <main class="min-h-screen bg-gray-50/50">
        <!-- Minimalist Hero Navbar Area -->
        <nav
            class="absolute top-0 w-full p-6 z-50 flex justify-between items-center animate-fade-in"
        >
            <a
                href="/#work"
                class="inline-flex items-center gap-2 text-white font-medium hover:text-indigo-200 transition-colors backdrop-blur-md bg-white/10 px-4 py-2 rounded-full border border-white/20"
            >
                <ArrowLeft className="w-4 h-4" /> Back to Directory
            </a>

            {
                project.websiteLink !== "#" && (
                    <a
                        href={project.websiteLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 text-gray-900 font-semibold bg-white px-5 py-2.5 rounded-full shadow-lg hover:bg-gray-50 transition-colors"
                    >
                        Visit Project <ExternalLink className="w-4 h-4" />
                    </a>
                )
            }
        </nav>

        <!-- Dynamic Hero Header -->
        <header
            class="relative w-full h-[65vh] md:h-[75vh] flex items-end pb-24 justify-center overflow-hidden bg-gray-900 border-b border-gray-200 group"
        >
            {/* Cinematic Image Background with Parallax effect */}
            <div class="absolute inset-0 z-0">
                <img
                    src={project.image}
                    alt={project.title}
                    class="w-full h-full object-cover opacity-50 mix-blend-overlay scale-100 group-hover:scale-105 transition-transform duration-[2s] ease-out"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-900/60 to-transparent"
                >
                </div>
            </div>

            <div
                class="container relative z-10 px-4 md:px-6 text-center max-w-4xl mx-auto flex flex-col items-center"
            >
                <div
                    class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-indigo-500/20 border border-indigo-400/30 text-indigo-300 text-[10px] font-bold tracking-widest uppercase mb-6 shadow-sm backdrop-blur-md animate-slide-up"
                    style="animation-delay: 0.1s;"
                >
                    {project.category}
                </div>
                <h1
                    class="text-4xl md:text-6xl lg:text-7xl font-display font-medium text-white tracking-tight leading-none mb-6 animate-slide-up drop-shadow-lg"
                    style="animation-delay: 0.2s;"
                >
                    {project.title}
                </h1>

                <div
                    class="mt-8 animate-slide-up"
                    style="animation-delay: 0.3s;"
                >
                    <a
                        href={project.websiteLink}
                        target={project.websiteLink !== "#"
                            ? "_blank"
                            : "_self"}
                        rel="noopener noreferrer"
                        class={`inline-flex items-center gap-3 px-8 py-4 rounded-full font-bold shadow-xl transition-all active:scale-95 text-lg ${
                            project.websiteLink !== "#"
                                ? "bg-white text-gray-950 hover:bg-gray-100 hover:shadow-2xl hover:-translate-y-1"
                                : "bg-gray-800 text-gray-400 border border-gray-700 cursor-not-allowed"
                        }`}
                    >
                        {
                            project.websiteLink !== "#"
                                ? "Visit Live Platform"
                                : "Coming Soon"
                        }
                        {
                            project.websiteLink !== "#" && (
                                <ExternalLink className="w-5 h-5" />
                            )
                        }
                    </a>
                </div>
            </div>
        </header>

        <!-- Detailed Content Section -->
        <section class="py-24 relative z-20">
            <div class="container px-4 md:px-6 mx-auto max-w-4xl">
                <div
                    class="bg-white shadow-xl shadow-gray-200/50 rounded-[2rem] p-8 md:p-14 -mt-32 relative z-20 border border-gray-100 animate-slide-up"
                    style="animation-delay: 0.4s;"
                >
                    <h2
                        class="text-3xl font-display font-bold text-gray-900 mb-8 pb-4 flex items-center gap-4"
                    >
                        Project Overview
                        <div class="flex-1 h-px bg-gray-100"></div>
                    </h2>
                    <p
                        class="text-gray-600 leading-relaxed text-lg md:text-xl font-medium tracking-tight mb-16 max-w-3xl"
                    >
                        {project.desc}
                    </p>

                    <div
                        class="grid grid-cols-1 md:grid-cols-2 gap-16 pt-8 border-t border-gray-100"
                    >
                        <div
                            class="animate-slide-up"
                            style="animation-delay: 0.5s;"
                        >
                            <h3
                                class="text-xl font-display font-bold text-gray-900 mb-6 flex items-center gap-3"
                            >
                                Core Objectives
                            </h3>
                            <ul class="space-y-4">
                                {
                                    project.objectives.map(
                                        (objective: string) => (
                                            <li class="flex items-start gap-3 text-gray-600 font-medium">
                                                <CheckCircle2 className="w-5 h-5 text-indigo-500 shrink-0 mt-0.5" />
                                                <span>{objective}</span>
                                            </li>
                                        )
                                    )
                                }
                            </ul>
                        </div>
                        <div
                            class="animate-slide-up"
                            style="animation-delay: 0.6s;"
                        >
                            <h3
                                class="text-xl font-display font-bold text-gray-900 mb-6"
                            >
                                Architecture & Stack
                            </h3>
                            <div class="flex flex-wrap gap-2.5">
                                {
                                    project.technologies.map((tech: string) => (
                                        <span class="px-4 py-2 bg-gray-50 border border-gray-200 text-gray-700 text-sm font-semibold rounded-xl hover:bg-gray-900 hover:text-white hover:border-gray-900 transition-colors cursor-default">
                                            {tech}
                                        </span>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    @keyframes slideUp {
        0% {
            opacity: 0;
            transform: translateY(40px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeIn {
        0% {
            opacity: 0;
        }
        100% {
            opacity: 1;
        }
    }

    .animate-slide-up {
        opacity: 0;
        animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .animate-fade-in {
        opacity: 0;
        animation: fadeIn 1s ease-out forwards;
    }
</style>
